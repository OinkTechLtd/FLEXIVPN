{
  "manifest_version": 3,
  "name": "FlexiVPN",
  "short_name": "FlexiVPN",
  "version": "1.0.0",
  "description": "Бесплатный VPN с защитой приватности и обходом блокировок. Быстрые серверы по всему миру.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "pages/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "FlexiVPN"
  },
  "background": {
    "service_worker": "scripts/background.js",
    "type": "module"
  },
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "proxy",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "options_page": "pages/options.html",
  "chrome_url_overrides": {},
  "content_scripts": [],
  "web_accessible_resources": [
    {
      "resources": ["pages/*", "styles/*", "icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
